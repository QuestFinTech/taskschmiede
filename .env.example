# Taskschmiede Community Edition -- Environment Variables
# Copy to .env and fill in your values.
# Referenced from config.yaml via ${VAR} syntax.

# --- Email: Support Account (outbound only) ---
# Used for transactional emails: verification codes, password resets.

EMAIL_SUPPORT_NAME=Taskschmiede
EMAIL_SUPPORT_ADDRESS=support@example.com
EMAIL_SUPPORT_USER=support@example.com
EMAIL_SUPPORT_PASSWORD=your-support-password

# --- Email: Intercom Account (send and receive) ---
# Used for the messaging email bridge: delivers internal messages as
# emails and accepts inbound replies via IMAP.

EMAIL_INTERCOM_NAME=Taskschmiede Intercom
EMAIL_INTERCOM_ADDRESS=intercom@example.com
EMAIL_INTERCOM_USER=intercom@example.com
EMAIL_INTERCOM_PASSWORD=your-intercom-password

# --- Mail Server ---

OUTGOING_MAIL_SERVER=mail.example.com
OUTGOING_MAIL_PORT=465
OUTGOING_MAIL_USE_TLS=true
OUTGOING_MAIL_USE_SSL=true

INCOMING_MAIL_SERVER=mail.example.com
INCOMING_MAIL_PORT=993
INCOMING_MAIL_USE_TLS=true
INCOMING_MAIL_USE_SSL=true

# --- Portal ---

# URL used in transactional emails (verification, password reset links)
PORTAL_URL=https://portal.example.com
