<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Taskschmiede</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f7; font-family:Arial, Helvetica, sans-serif;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f7;">
<tr><td align="center" style="padding:40px 20px;">
<table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden;">

<!-- Header -->
<tr><td style="background-color:#1a1a2e; padding:24px 40px; text-align:center;">
  <span style="color:#ffffff; font-size:22px; font-weight:bold; letter-spacing:1px;">TASKSCHMIEDE</span>
</td></tr>

<!-- Body -->
<tr><td style="padding:40px;">
  <p style="margin:0 0 20px; color:#333333; font-size:16px; line-height:1.5;">{{.Greeting}},</p>
  <p style="margin:0 0 24px; color:#333333; font-size:16px; line-height:1.5;">{{.Intro}}</p>

  <!-- Code box -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:8px 0 24px;">
    <div style="background-color:#f0f0f5; border:2px solid #d0d0da; border-radius:8px; padding:20px 32px; display:inline-block;">
      <span style="font-family:'Courier New', monospace; font-size:32px; font-weight:bold; letter-spacing:4px; color:#1a1a2e;">{{.Code}}</span>
    </div>
  </td></tr>
  </table>

  {{if .ActionURL}}
  <!-- CTA button -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <tr><td align="center" style="padding:0 0 24px;">
    <a href="{{.ActionURL}}" target="_blank" style="display:inline-block; background-color:#1a1a2e; color:#ffffff; text-decoration:none; font-size:16px; font-weight:bold; padding:14px 32px; border-radius:6px;">{{.ButtonText}}</a>
  </td></tr>
  </table>

  <p style="margin:0 0 16px; color:#666666; font-size:14px; line-height:1.5; text-align:center;">{{.ManualNote}}</p>
  {{end}}

  <p style="margin:0 0 32px; color:#888888; font-size:13px; line-height:1.5; text-align:center;">{{.ExpiryNote}}</p>

  <p style="margin:0 0 4px; color:#333333; font-size:16px; line-height:1.5;">{{.Closing}}</p>
  <p style="margin:0; color:#333333; font-size:16px; font-weight:bold; line-height:1.5;">{{.TeamName}}</p>
</td></tr>

<!-- Footer -->
<tr><td style="background-color:#f4f4f7; padding:20px 40px; text-align:center; border-top:1px solid #e8e8ee;">
  <p style="margin:0; color:#999999; font-size:12px; line-height:1.5;">This is an automated message from Taskschmiede. Please do not reply.</p>
</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
